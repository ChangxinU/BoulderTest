{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "HoldPredictionList",
  "type": "object",
  "required": ["image_size", "holds"],
  "properties": {
    "image_size": {
      "type": "array",
      "items": { "type": "integer" },
      "minItems": 2,
      "maxItems": 2
    },
    "holds": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "hold_id",
          "score",
          "class_name",
          "contour_points",
          "normalized_contour_points"
        ],
        "properties": {
          "hold_id": { "type": "string" },
          "score": { "type": "number" },
          "class_name": { "type": "string" },
          "bbox": {
            "type": "array",
            "items": { "type": "number" },
            "minItems": 4,
            "maxItems": 4
          },
          "mask_size": {
            "type": "array",
            "items": { "type": "integer" },
            "minItems": 2,
            "maxItems": 2
          },
          "contour_points": {
            "type": "array",
            "items": {
              "type": "array",
              "items": { "type": "number" },
              "minItems": 2,
              "maxItems": 2
            }
          },
          "normalized_contour_points": {
            "type": "array",
            "items": {
              "type": "array",
              "items": { "type": "number" },
              "minItems": 2,
              "maxItems": 2
            }
          },
          "metadata": {
            "type": "object"
          }
        }
      }
    }
  }
}
